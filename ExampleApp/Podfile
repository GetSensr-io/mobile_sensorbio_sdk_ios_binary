platform :ios, '18.0'
inhibit_all_warnings!

# SensorBioSDK consumed from the umbrella binary podspec at the repo root
# (one level up). `:path` resolves the in-tree podspec + xcframeworks under
# ../SensorBio/ so changes from a fresh build-xcframeworks.sh run in the
# SDK source repo flow straight through. Customer-style integration is
# `:git`/`:tag` against the same podspec — see ../README.md.
target 'ExampleApp' do
  use_frameworks!

  pod 'SensorBioSDK', :path => '..'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # SensorBioSDK is iOS 18+; transitive pods default lower. Bump them all.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']  = '18.0'
      # abseil (transitive via gRPC-Core) static-asserts __cplusplus >= 201703L.
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      config.build_settings['CLANG_CXX_LIBRARY']           = 'libc++'
      config.build_settings['CODE_SIGNING_ALLOWED']        = 'NO'
      # SensorBioSDK.xcframework was built with -enable-library-evolution.
      # Its Job subclasses reference SwiftQueue's `Job.onRetry` via Swift
      # method descriptors (a library-evolution indirection). For those
      # descriptors to exist, SwiftQueue (and every other Swift pod the
      # SDK extends/conforms-to types from) has to be compiled with
      # library-evolution too. Setting it project-wide is the simplest
      # path — pure-Obj-C pods ignore the flag.
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end
  end
end
