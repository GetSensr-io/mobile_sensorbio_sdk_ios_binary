.DS_Store

# Xcode per-user state
.swiftpm/xcode/xcuserdata/
.swiftpm/xcode/package.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# CocoaPods — ExampleApp regenerates Pods/ on `pod install`; don't commit it.
# Podfile.lock IS committed so customers run against the same resolution.
ExampleApp/Pods/
ExampleApp/*.xcworkspace/
